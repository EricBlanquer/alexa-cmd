#!/usr/bin/env python3
"""alexa-cmd: Send text commands to Alexa devices via command line.

Uses Amazon's Alexa web API with cookie-based authentication.

Usage:
    alexa setup                              # First-time auth setup
    alexa devices                            # List devices
    alexa default <name>                     # Set default device
    alexa send allume la lumiere             # Send text command
    alexa send -d echo eteins la lumiere     # Send to specific device
    alexa say bonjour tout le monde          # Text-to-speech
"""

import argparse
import json
import sys
from pathlib import Path

import requests

CONFIG_DIR = Path.home() / ".config" / "alexa-cmd"
COOKIE_FILE = CONFIG_DIR / "cookies.txt"
DEVICES_FILE = CONFIG_DIR / "devices.json"
CONFIG_FILE = CONFIG_DIR / "config.json"

ALEXA_URL = "https://alexa.amazon.fr"

HEADERS = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
                  "(KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
    "Accept": "application/json",
    "Accept-Language": "fr-FR,fr;q=0.9",
    "Origin": ALEXA_URL,
    "Referer": ALEXA_URL + "/spa/index.html",
}


def load_config():
    if CONFIG_FILE.exists():
        return json.loads(CONFIG_FILE.read_text())
    return {}


def save_config(config):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(config, indent=2))


def build_session():
    if not COOKIE_FILE.exists():
        print("Pas de cookies. Lance 'alexa setup' d'abord.", file=sys.stderr)
        sys.exit(1)

    session = requests.Session()
    session.headers.update(HEADERS)

    cookie_str = COOKIE_FILE.read_text().strip()
    for pair in cookie_str.split(";"):
        pair = pair.strip()
        if "=" in pair:
            name, _, value = pair.partition("=")
            session.cookies.set(name.strip(), value.strip())

    csrf = session.cookies.get("csrf")
    if csrf:
        session.headers["csrf"] = csrf

    return session


def check_response(resp):
    if resp.status_code == 401:
        print("Session expiree. Relance 'alexa setup'.", file=sys.stderr)
        sys.exit(1)
    resp.raise_for_status()


def fetch_devices():
    session = build_session()
    resp = session.get(ALEXA_URL + "/api/devices-v2/device")
    check_response(resp)

    data = resp.json()
    devices = []
    customer_id = None
    for d in data.get("devices", []):
        family = d.get("deviceFamily", "")
        caps = d.get("capabilities", [])
        if isinstance(caps, list) and caps and isinstance(caps[0], str):
            cap_names = caps
        else:
            cap_names = [c.get("capabilityName", "") for c in caps]
        is_interactive = (
            "AUDIO_PLAYER" in cap_names
            or "ALEXA_VOICE_ENABLED" in cap_names
            or family in ("ECHO", "THIRD_PARTY_AVS_MEDIA_DISPLAY",
                          "THIRD_PARTY_AVS_SONOS_BOOTLEG", "WHA")
        )
        if is_interactive:
            if not customer_id:
                customer_id = d.get("deviceOwnerCustomerId")
            devices.append({
                "name": d.get("accountName", "Unknown"),
                "serial": d["serialNumber"],
                "type": d["deviceType"],
                "family": family,
            })

    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    DEVICES_FILE.write_text(json.dumps(devices, indent=2))
    if customer_id:
        config = load_config()
        config["customer_id"] = customer_id
        save_config(config)
    return devices


def get_devices():
    if DEVICES_FILE.exists():
        return json.loads(DEVICES_FILE.read_text())
    return fetch_devices()


def find_device(name=None):
    devices = get_devices()
    if not devices:
        print("Aucun appareil. Lance 'alexa devices'.", file=sys.stderr)
        sys.exit(1)

    if name:
        for d in devices:
            if name.lower() in d["name"].lower():
                return d
        print(f"Appareil '{name}' non trouve. Disponibles :", file=sys.stderr)
        for d in devices:
            print(f"  - {d['name']}", file=sys.stderr)
        sys.exit(1)

    config = load_config()
    default_name = config.get("default_device")
    if default_name:
        for d in devices:
            if d["name"] == default_name:
                return d

    return devices[0]


def send_behavior(session, behavior_type, payload, device):
    config = load_config()
    customer_id = config.get("customer_id", "")

    body = {
        "behaviorId": "PREVIEW",
        "sequenceJson": json.dumps({
            "@type": "com.amazon.alexa.behaviors.model.Sequence",
            "startNode": {
                "@type": "com.amazon.alexa.behaviors.model.OpaquePayloadOperationNode",
                "type": behavior_type,
                "operationPayload": {
                    **payload,
                    "locale": "fr-FR",
                    "deviceType": device["type"],
                    "deviceSerialNumber": device["serial"],
                    "customerId": customer_id,
                },
            },
        }),
        "status": "ENABLED",
    }

    resp = session.post(ALEXA_URL + "/api/behaviors/preview", json=body)
    check_response(resp)
    return resp


# ── Commands ──────────────────────────────────────────────────────────

def cmd_setup(_args):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    print("=== Configuration alexa-cmd ===\n")
    print("1. Ouvre https://alexa.amazon.fr/api/devices-v2/device dans ton navigateur")
    print("   (tu seras redirige vers le login Amazon, connecte-toi)")
    print("2. Apres login, tu verras du JSON : les appareils sont detectes")
    print("3. Ouvre DevTools (F12) > onglet Network (Reseau)")
    print("4. Rafraichis la page (F5)")
    print("5. Clique sur la requete 'device'")
    print("6. Dans Request Headers, copie la valeur complete du header 'Cookie'")
    print("7. Colle-la ci-dessous :\n")

    cookie_str = input("Cookie: ").strip()
    if not cookie_str:
        print("Aucun cookie fourni.", file=sys.stderr)
        sys.exit(1)

    COOKIE_FILE.write_text(cookie_str)
    COOKIE_FILE.chmod(0o600)
    print(f"\nCookies sauvegardes dans {COOKIE_FILE}")

    print("\nVerification...")
    try:
        devices = fetch_devices()
    except Exception as ex:
        print(f"Erreur : {ex}", file=sys.stderr)
        print("Verifie que les cookies sont corrects.", file=sys.stderr)
        sys.exit(1)

    if not devices:
        print("Aucun appareil interactif trouve.")
        return

    print(f"\n{len(devices)} appareil(s) :")
    for i, d in enumerate(devices, 1):
        print(f"  {i}. {d['name']} ({d['family']})")

    config = load_config()
    config["default_device"] = devices[0]["name"]
    save_config(config)
    print(f"\nAppareil par defaut : {devices[0]['name']}")
    print("Change avec : alexa default <nom>")


def cmd_devices(_args):
    devices = fetch_devices()
    config = load_config()
    default_name = config.get("default_device", "")

    if not devices:
        print("Aucun appareil interactif trouve.")
        return

    for d in devices:
        marker = " *" if d["name"] == default_name else ""
        print(f"  {d['name']} ({d['family']}){marker}")


def cmd_default(args):
    devices = fetch_devices()
    name = " ".join(args.name)
    matched = None
    for d in devices:
        if name.lower() in d["name"].lower():
            matched = d
            break

    if not matched:
        print(f"Appareil '{name}' non trouve. Disponibles :", file=sys.stderr)
        for d in devices:
            print(f"  - {d['name']}", file=sys.stderr)
        sys.exit(1)

    config = load_config()
    config["default_device"] = matched["name"]
    save_config(config)
    print(f"Appareil par defaut : {matched['name']}")


def cmd_send(args):
    text = " ".join(args.text)
    if not text:
        print("Commande vide.", file=sys.stderr)
        sys.exit(1)

    device = find_device(args.device)
    session = build_session()
    resp = send_behavior(session, "Alexa.TextCommand", {"text": text}, device)

    if resp.status_code == 200:
        print(f"-> {device['name']} : {text}")
    else:
        print(f"Erreur {resp.status_code} : {resp.text}", file=sys.stderr)
        sys.exit(1)


def cmd_say(args):
    text = " ".join(args.text)
    if not text:
        print("Texte vide.", file=sys.stderr)
        sys.exit(1)

    device = find_device(args.device)
    session = build_session()
    resp = send_behavior(session, "Alexa.Speak", {"textToSpeak": text}, device)

    if resp.status_code == 200:
        print(f">> {device['name']} : {text}")
    else:
        print(f"Erreur {resp.status_code} : {resp.text}", file=sys.stderr)
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(
        prog="alexa",
        description="Envoie des commandes texte a Alexa depuis le terminal",
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("setup", help="Configurer l'authentification")
    sub.add_parser("devices", help="Lister les appareils Alexa")

    p_def = sub.add_parser("default", help="Definir l'appareil par defaut")
    p_def.add_argument("name", nargs="+", help="Nom de l'appareil (correspondance partielle)")

    p_send = sub.add_parser("send", help="Envoyer une commande texte")
    p_send.add_argument("text", nargs="+", help="Commande a envoyer")
    p_send.add_argument("-d", "--device", help="Appareil cible (correspondance partielle)")

    p_say = sub.add_parser("say", help="Faire parler Alexa (TTS)")
    p_say.add_argument("text", nargs="+", help="Texte a prononcer")
    p_say.add_argument("-d", "--device", help="Appareil cible (correspondance partielle)")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    commands = {
        "setup": cmd_setup,
        "devices": cmd_devices,
        "default": cmd_default,
        "send": cmd_send,
        "say": cmd_say,
    }
    commands[args.command](args)


if __name__ == "__main__":
    main()
