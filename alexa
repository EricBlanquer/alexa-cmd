#!/usr/bin/env python3
"""alexa-cmd: Send text commands to Alexa devices via command line.

Detects the default web browser (Firefox / Chrome / Chromium / Brave) and reads
its session cookies live from disk. On missing/expired session, opens that
browser to the Alexa login page and polls until the user is authenticated.
"""

import argparse
import configparser
import hashlib
import json
import shutil
import sqlite3
import subprocess
import sys
import tempfile
import time
from pathlib import Path

import requests

CONFIG_DIR = Path.home() / ".config" / "alexa-cmd"
DEVICES_FILE = CONFIG_DIR / "devices.json"
CONFIG_FILE = CONFIG_DIR / "config.json"

FIREFOX_DIR = Path.home() / ".mozilla" / "firefox"
ALEXA_URL = "https://alexa.amazon.fr"
DEVICES_PATH = "/api/devices-v2/device"
LOGIN_TIMEOUT_SEC = 300
POLL_INTERVAL_SEC = 2

KNOWN_COMMANDS = {"setup", "devices", "default", "send", "say"}

CHROMIUM_BROWSERS = {
    "chrome": {
        "label": "Chrome",
        "commands": ["google-chrome", "google-chrome-stable"],
        "db": Path.home() / ".config/google-chrome/Default/Cookies",
        "keyring": "chrome",
    },
    "chromium": {
        "label": "Chromium",
        "commands": ["chromium", "chromium-browser"],
        "db": Path.home() / ".config/chromium/Default/Cookies",
        "keyring": "chromium",
    },
    "brave": {
        "label": "Brave",
        "commands": ["brave-browser", "brave"],
        "db": Path.home() / ".config/BraveSoftware/Brave-Browser/Default/Cookies",
        "keyring": "brave",
    },
}

HEADERS = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
                  "(KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
    "Accept": "application/json",
    "Accept-Language": "fr-FR,fr;q=0.9",
    "Origin": ALEXA_URL,
    "Referer": ALEXA_URL + "/spa/index.html",
}


def load_config():
    if CONFIG_FILE.exists():
        return json.loads(CONFIG_FILE.read_text())
    return {}


def save_config(config):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(config, indent=2))


def find_firefox_profile():
    profiles_ini = FIREFOX_DIR / "profiles.ini"
    if not profiles_ini.exists():
        return None
    cp = configparser.ConfigParser()
    cp.read(profiles_ini)
    for section in cp.sections():
        if section.startswith("Install"):
            default = cp[section].get("Default")
            if default:
                path = FIREFOX_DIR / default
                if path.exists():
                    return path
    for section in cp.sections():
        if section.startswith("Profile") and cp[section].get("Default") == "1":
            rel = cp[section].get("Path")
            if rel:
                path = FIREFOX_DIR / rel
                if path.exists():
                    return path
    return None


def first_in_path(commands):
    for cmd in commands:
        if shutil.which(cmd):
            return cmd
    return None


def detect_default_browser_id():
    try:
        out = subprocess.check_output(
            ["xdg-settings", "get", "default-web-browser"],
            stderr=subprocess.DEVNULL,
            timeout=5,
        ).decode().strip().lower()
    except (FileNotFoundError, subprocess.CalledProcessError, subprocess.TimeoutExpired):
        return None
    if "firefox" in out:
        return "firefox"
    if "chromium" in out:
        return "chromium"
    if "brave" in out:
        return "brave"
    if "chrome" in out:
        return "chrome"
    return None


def build_browser_info(browser_id):
    if browser_id == "firefox":
        profile = find_firefox_profile()
        cmd = first_in_path(["firefox", "firefox-esr"])
        if not profile or not cmd:
            return None
        return {"id": "firefox", "type": "firefox", "label": "Firefox",
                "command": cmd, "profile": profile}
    cfg = CHROMIUM_BROWSERS.get(browser_id)
    if not cfg or not cfg["db"].exists():
        return None
    cmd = first_in_path(cfg["commands"])
    if not cmd:
        return None
    return {"id": browser_id, "type": "chromium", "label": cfg["label"],
            "command": cmd, "db": cfg["db"], "keyring": cfg["keyring"]}


def browser_has_readable_amazon_cookies(browser):
    if browser["type"] == "firefox":
        return True
    cookies = read_chromium_cookies(browser)
    return any(name in cookies for name in ("session-id", "ubid-acbfr", "session-token"))


def find_browser():
    candidates = []
    detected = detect_default_browser_id()
    if detected:
        candidates.append(detected)
    for bid in ("firefox", "chrome", "chromium", "brave"):
        if bid not in candidates:
            candidates.append(bid)
    fallback = None
    for bid in candidates:
        info = build_browser_info(bid)
        if not info:
            continue
        if browser_has_readable_amazon_cookies(info):
            return info
        if fallback is None:
            fallback = info
    return fallback


def require_browser():
    info = find_browser()
    if not info:
        print("Aucun navigateur supporte trouve (Firefox/Chrome/Chromium/Brave).",
              file=sys.stderr)
        sys.exit(1)
    return info


def read_firefox_cookies(profile):
    src = profile / "cookies.sqlite"
    if not src.exists():
        return {}
    with tempfile.TemporaryDirectory(prefix="alexa-cookies-") as tmp:
        tmp_dir = Path(tmp)
        for ext in ("", "-wal", "-shm"):
            f = profile / f"cookies.sqlite{ext}"
            if f.exists():
                try:
                    shutil.copy2(f, tmp_dir / f.name)
                except OSError:
                    pass
        copied = tmp_dir / "cookies.sqlite"
        if not copied.exists():
            return {}
        try:
            conn = sqlite3.connect(f"file:{copied}?mode=ro", uri=True, timeout=5.0)
        except sqlite3.Error:
            return {}
        try:
            cur = conn.execute(
                "SELECT name, value FROM moz_cookies "
                "WHERE host LIKE '%amazon.fr' "
                "AND (originAttributes = '' OR originAttributes IS NULL) "
                "ORDER BY lastAccessed DESC, expiry DESC"
            )
            cookies = {}
            for name, value in cur:
                cookies.setdefault(name, value)
            return cookies
        except sqlite3.Error:
            return {}
        finally:
            conn.close()


def get_keyring_password(app):
    try:
        out = subprocess.check_output(
            ["secret-tool", "lookup", "application", app],
            stderr=subprocess.DEVNULL,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.CalledProcessError, subprocess.TimeoutExpired):
        return None
    return out.decode("utf-8").strip() or None


def decrypt_chromium_value(encrypted, host_key, keyring_password, has_integrity_prefix):
    if not encrypted:
        return ""
    prefix = encrypted[:3]
    if prefix == b"v10":
        password = "peanuts"
    elif prefix == b"v11":
        if not keyring_password:
            raise RuntimeError("Mot de passe keyring requis pour cookies v11")
        password = keyring_password
    else:
        return encrypted.decode("utf-8", errors="replace")
    from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
    body = encrypted[3:]
    key = hashlib.pbkdf2_hmac("sha1", password.encode(), b"saltysalt", 1, 16)
    cipher = Cipher(algorithms.AES(key), modes.CBC(b" " * 16))
    decryptor = cipher.decryptor()
    decrypted = decryptor.update(body) + decryptor.finalize()
    pad = decrypted[-1]
    payload = decrypted[:-pad]
    if has_integrity_prefix:
        expected = hashlib.sha256(host_key.encode()).digest()
        if payload[:32] != expected:
            raise RuntimeError("Integrity prefix mismatch")
        payload = payload[32:]
    return payload.decode("utf-8")


def read_chromium_cookies(browser):
    db = browser["db"]
    if not db.exists():
        return {}
    keyring_password = get_keyring_password(browser["keyring"])
    with tempfile.TemporaryDirectory(prefix="alexa-cookies-") as tmp:
        copied = Path(tmp) / "Cookies"
        try:
            shutil.copy2(db, copied)
        except OSError:
            return {}
        try:
            conn = sqlite3.connect(f"file:{copied}?mode=ro", uri=True, timeout=5.0)
        except sqlite3.Error:
            return {}
        try:
            try:
                row = conn.execute(
                    "SELECT value FROM meta WHERE key = 'version'"
                ).fetchone()
                version = int(row[0]) if row else 0
            except (sqlite3.Error, ValueError, TypeError):
                version = 0
            has_integrity_prefix = version >= 24
            cur = conn.execute(
                "SELECT host_key, name, encrypted_value FROM cookies "
                "WHERE host_key LIKE '%amazon.fr' "
                "ORDER BY last_access_utc DESC, expires_utc DESC"
            )
            cookies = {}
            for host_key, name, enc in cur:
                if name in cookies:
                    continue
                try:
                    cookies[name] = decrypt_chromium_value(
                        enc, host_key, keyring_password, has_integrity_prefix,
                    )
                except Exception:
                    continue
            return cookies
        except sqlite3.Error:
            return {}
        finally:
            conn.close()


def read_browser_cookies(browser):
    if browser["type"] == "firefox":
        return read_firefox_cookies(browser["profile"])
    if browser["type"] == "chromium":
        return read_chromium_cookies(browser)
    return {}


def make_session(cookies):
    session = requests.Session()
    session.headers.update(HEADERS)
    for name, value in cookies.items():
        session.cookies.set(name, value)
    csrf = cookies.get("csrf")
    if csrf:
        session.headers["csrf"] = csrf
    return session


def cookies_look_complete(cookies):
    return "session-token" in cookies and "csrf" in cookies


def cookies_are_valid(cookies):
    if not cookies_look_complete(cookies):
        return False
    session = make_session(cookies)
    try:
        resp = session.get(ALEXA_URL + DEVICES_PATH, timeout=10, allow_redirects=False)
    except requests.RequestException:
        return False
    return resp.status_code == 200


def auto_login(browser):
    cookies = read_browser_cookies(browser)
    if cookies_are_valid(cookies):
        return cookies

    print(f"Authentification requise. Ouverture de {browser['label']}...",
          file=sys.stderr)
    try:
        subprocess.Popen(
            [browser["command"], ALEXA_URL + DEVICES_PATH],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except FileNotFoundError:
        print(f"{browser['label']} introuvable dans le PATH.", file=sys.stderr)
        sys.exit(1)

    print(
        f"Connecte-toi a Amazon dans {browser['label']} (timeout {LOGIN_TIMEOUT_SEC}s)...",
        file=sys.stderr,
    )
    deadline = time.time() + LOGIN_TIMEOUT_SEC
    while time.time() < deadline:
        time.sleep(POLL_INTERVAL_SEC)
        cookies = read_browser_cookies(browser)
        if cookies_are_valid(cookies):
            print("Connexion etablie.", file=sys.stderr)
            return cookies

    print("Timeout d'authentification.", file=sys.stderr)
    sys.exit(1)


def authed_request(call):
    browser = require_browser()
    cookies = read_browser_cookies(browser)
    if not cookies_look_complete(cookies):
        cookies = auto_login(browser)
    session = make_session(cookies)
    resp = call(session)
    if resp.status_code in (302, 401):
        cookies = auto_login(browser)
        session = make_session(cookies)
        resp = call(session)
    resp.raise_for_status()
    return resp


def fetch_devices():
    resp = authed_request(
        lambda s: s.get(ALEXA_URL + DEVICES_PATH, allow_redirects=False)
    )
    data = resp.json()
    devices = []
    customer_id = None
    for d in data.get("devices", []):
        family = d.get("deviceFamily", "")
        caps = d.get("capabilities", [])
        if isinstance(caps, list) and caps and isinstance(caps[0], str):
            cap_names = caps
        else:
            cap_names = [c.get("capabilityName", "") for c in caps]
        is_interactive = (
            "AUDIO_PLAYER" in cap_names
            or "ALEXA_VOICE_ENABLED" in cap_names
            or family in ("ECHO", "THIRD_PARTY_AVS_MEDIA_DISPLAY",
                          "THIRD_PARTY_AVS_SONOS_BOOTLEG", "WHA")
        )
        if is_interactive:
            if not customer_id:
                customer_id = d.get("deviceOwnerCustomerId")
            devices.append({
                "name": d.get("accountName", "Unknown"),
                "serial": d["serialNumber"],
                "type": d["deviceType"],
                "family": family,
            })

    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    DEVICES_FILE.write_text(json.dumps(devices, indent=2))
    if customer_id:
        config = load_config()
        config["customer_id"] = customer_id
        save_config(config)
    return devices


def get_devices():
    if DEVICES_FILE.exists():
        return json.loads(DEVICES_FILE.read_text())
    return fetch_devices()


def find_device(name=None):
    devices = get_devices()
    if not devices:
        print("Aucun appareil. Lance 'alexa devices'.", file=sys.stderr)
        sys.exit(1)

    if name:
        for d in devices:
            if name.lower() in d["name"].lower():
                return d
        print(f"Appareil '{name}' non trouve. Disponibles :", file=sys.stderr)
        for d in devices:
            print(f"  - {d['name']}", file=sys.stderr)
        sys.exit(1)

    config = load_config()
    default_name = config.get("default_device")
    if default_name:
        for d in devices:
            if d["name"] == default_name:
                return d

    return devices[0]


def send_behavior(behavior_type, payload, device):
    config = load_config()
    customer_id = config.get("customer_id", "")

    body = {
        "behaviorId": "PREVIEW",
        "sequenceJson": json.dumps({
            "@type": "com.amazon.alexa.behaviors.model.Sequence",
            "startNode": {
                "@type": "com.amazon.alexa.behaviors.model.OpaquePayloadOperationNode",
                "type": behavior_type,
                "operationPayload": {
                    **payload,
                    "locale": "fr-FR",
                    "deviceType": device["type"],
                    "deviceSerialNumber": device["serial"],
                    "customerId": customer_id,
                },
            },
        }),
        "status": "ENABLED",
    }

    return authed_request(
        lambda s: s.post(ALEXA_URL + "/api/behaviors/preview", json=body,
                         allow_redirects=False)
    )


# ── Commands ──────────────────────────────────────────────────────────

def cmd_setup(_args):
    browser = require_browser()
    print(f"Navigateur detecte : {browser['label']}", file=sys.stderr)
    cookies = auto_login(browser)
    if not cookies_are_valid(cookies):
        print("Cookies invalides apres login.", file=sys.stderr)
        sys.exit(1)

    print("Recuperation des appareils...")
    devices = fetch_devices()
    if not devices:
        print("Aucun appareil interactif trouve.")
        return

    print(f"\n{len(devices)} appareil(s) :")
    for i, d in enumerate(devices, 1):
        print(f"  {i}. {d['name']} ({d['family']})")

    config = load_config()
    if not config.get("default_device"):
        config["default_device"] = devices[0]["name"]
        save_config(config)
        print(f"\nAppareil par defaut : {devices[0]['name']}")
        print("Change avec : alexa default <nom>")


def cmd_devices(_args):
    devices = fetch_devices()
    config = load_config()
    default_name = config.get("default_device", "")

    if not devices:
        print("Aucun appareil interactif trouve.")
        return

    for d in devices:
        marker = " *" if d["name"] == default_name else ""
        print(f"  {d['name']} ({d['family']}){marker}")


def cmd_default(args):
    devices = fetch_devices()
    name = " ".join(args.name)
    matched = None
    for d in devices:
        if name.lower() in d["name"].lower():
            matched = d
            break

    if not matched:
        print(f"Appareil '{name}' non trouve. Disponibles :", file=sys.stderr)
        for d in devices:
            print(f"  - {d['name']}", file=sys.stderr)
        sys.exit(1)

    config = load_config()
    config["default_device"] = matched["name"]
    save_config(config)
    print(f"Appareil par defaut : {matched['name']}")


def cmd_send(args):
    text = " ".join(args.text)
    if not text:
        print("Commande vide.", file=sys.stderr)
        sys.exit(1)

    device = find_device(args.device)
    resp = send_behavior("Alexa.TextCommand", {"text": text}, device)

    if resp.status_code == 200:
        print(f"-> {device['name']} : {text}")
    else:
        print(f"Erreur {resp.status_code} : {resp.text}", file=sys.stderr)
        sys.exit(1)


def cmd_say(args):
    text = " ".join(args.text)
    if not text:
        print("Texte vide.", file=sys.stderr)
        sys.exit(1)

    device = find_device(args.device)
    resp = send_behavior("Alexa.Speak", {"textToSpeak": text}, device)

    if resp.status_code == 200:
        print(f">> {device['name']} : {text}")
    else:
        print(f"Erreur {resp.status_code} : {resp.text}", file=sys.stderr)
        sys.exit(1)


def main():
    if len(sys.argv) > 1:
        first = sys.argv[1]
        if first not in KNOWN_COMMANDS and first not in ("-h", "--help"):
            sys.argv.insert(1, "send")

    parser = argparse.ArgumentParser(
        prog="alexa",
        description="Envoie des commandes texte a Alexa depuis le terminal",
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("setup", help="Re-authentifier et lister les appareils")
    sub.add_parser("devices", help="Lister les appareils Alexa")

    p_def = sub.add_parser("default", help="Definir l'appareil par defaut")
    p_def.add_argument("name", nargs="+", help="Nom de l'appareil (correspondance partielle)")

    p_send = sub.add_parser("send", help="Envoyer une commande texte (par defaut)")
    p_send.add_argument("text", nargs="+", help="Commande a envoyer")
    p_send.add_argument("-d", "--device", help="Appareil cible (correspondance partielle)")

    p_say = sub.add_parser("say", help="Faire parler Alexa (TTS)")
    p_say.add_argument("text", nargs="+", help="Texte a prononcer")
    p_say.add_argument("-d", "--device", help="Appareil cible (correspondance partielle)")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    commands = {
        "setup": cmd_setup,
        "devices": cmd_devices,
        "default": cmd_default,
        "send": cmd_send,
        "say": cmd_say,
    }
    commands[args.command](args)


if __name__ == "__main__":
    main()
